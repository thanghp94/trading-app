# Server
PORT=3001

# Auth — bearer token required on the WS handshake
APP_AUTH_TOKEN=change-me-to-a-random-32-char-string

# TwelveData — for real spot XAU/USD and forex pairs (works in VN).
# Sign up at https://twelvedata.com/register (free, ~2 min).
# Free tier: 800 req/day, 8 req/min. Adapter polls 110-180s per stream
# to stay safely under the daily quota for 1-2 active symbols.
# TWELVEDATA_API_KEY=

# OANDA practice account — alternative forex source. NOTE: OANDA blocks
# Vietnamese IPs, so this won't work from VN. Kept here for users in
# regions where OANDA is reachable.
# Sign up at https://www.oanda.com/apply/practice/ then generate a Personal
# Access Token at hub.oanda.com → Manage API Access.
# OANDA_API_TOKEN=
# OANDA_ACCOUNT_ID=

# Telegram bot — for alert delivery (W3.1).
# 1. Talk to @BotFather on Telegram → /newbot → follow prompts → copy token
# 2. Send any message to your bot, then visit
#    https://api.telegram.org/bot<TOKEN>/getUpdates → find "chat":{"id":...}
# 3. Paste both below and restart.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Always-on alert symbols. Comma-separated SYMBOL:TF pairs. The server
# subscribes to each on startup so alerts fire even with no UI open AND
# the watchlist scanner can rank them.
# Symbols opened in the UI also get evaluators, but they stop when the
# server restarts unless they're listed here.
# Example:
# ALERT_SYMBOLS=BTCUSDT:5m,ETHUSDT:15m,XAUUSD:1h,SOLUSDT:5m
# ALERT_SYMBOLS=

# Outbound webhooks — comma-separated URLs. Every fired alert is POSTed
# to each. Discord and Slack webhook URLs auto-format; everything else
# gets {"alert": <Alert>} JSON.
# Example:
# ALERT_WEBHOOK_URLS=https://discord.com/api/webhooks/123/abc,https://hooks.slack.com/services/T0/B0/XXX
# ALERT_WEBHOOK_URLS=

# Anthropic API — for the per-cell "Analyze" button (Claude Haiku).
# Sign up at https://console.anthropic.com → Settings → API Keys → Create.
# Cost: ~$0.0015 per analysis (Haiku is cheap).
# ANTHROPIC_API_KEY=

# AI Trading Council (multi-agent advisory pipeline). Disabled by default
# because each /api/council call runs ~12 LLM calls (~$0.03-0.05 each).
# 11× Claude Haiku 4.5 + 1× Claude Sonnet 4.6 (Portfolio Manager, tool-use).
# Endpoint /api/council is NOT registered until COUNCIL_ENABLED=true.
# COUNCIL_ENABLED=false
# COUNCIL_CACHE_TTL_MS=14400000

# Auto-analyze on every fired alert (attaches AI summary to the alert).
# Costs ~$0.0015 per alert; budget accordingly. Default off.
# ANALYZE_ON_ALERT=true

# Risk-management guards. Suppress alerts after N losses today or X negative
# R sum today. 0 = disabled. Saves you from yourself on bad days.
# MAX_LOSSES_PER_DAY=3
# MAX_DRAWDOWN_R=4

# Trade journal SQLite file (defaults to data/journal.db relative to cwd).
# JOURNAL_DB_PATH=data/journal.db

# VN broker creds (Weekend 3.2 — for full broker integration; not required
# if you're happy with the free TCBS feed which works out of the box).
# DNSE_USERNAME=
# DNSE_PASSWORD=

# ───────────────────── AUTO-EXECUTION (DANGER ZONE) ─────────────────────
#
# When configured, the server places orders automatically on every fired
# alert that matches the allowlist. DEFAULT IS OFF. If you don't know what
# this does, leave it off.
#
# Modes:
#   off      — no orders placed (default if unset)
#   dry-run  — logs would-be orders to console + /api/execution/history.
#              No real money. Use this to verify your allowlist + risk.
#   live     — actually places orders. ALSO REQUIRES AUTO_EXECUTE_LIVE=true
#              as a second gate. The live path is a stub by default —
#              wire your broker SDK in src/server/execution/auto-executor.ts.
#
# AUTO_EXECUTE_MODE=off
# AUTO_EXECUTE_LIVE=false
#
# Allowlist of (rule:symbol) pairs. Wildcard "*" matches anything.
# Empty list = no orders placed even in dry-run.
# AUTO_EXECUTE_ALLOW=wave-3-entry:BTCUSDT,wave-5-entry:ETHUSDT,*:XAUUSD
#
# Risk per trade in % of balance. Same convention as the position sizer.
# AUTO_EXECUTE_RISK_PCT=0.5
# AUTO_EXECUTE_SL_PCT=0.005
# AUTO_EXECUTE_RR=2
# AUTO_EXECUTE_BALANCE=10000
