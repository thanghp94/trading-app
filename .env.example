# Server
PORT=3001

# Auth — bearer token required on the WS handshake
APP_AUTH_TOKEN=change-me-to-a-random-32-char-string

# OANDA practice account — for real spot XAU/USD and forex pairs.
# Sign up at https://www.oanda.com/apply/practice/ (or developer.oanda.com).
# After signup: hub.oanda.com → Manage API Access → generate a Personal Access Token.
# Account ID is on the same page (looks like 101-001-12345678-001).
# OANDA_API_TOKEN=
# OANDA_ACCOUNT_ID=

# Telegram (Weekend 3)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# VN broker creds (Weekend 3.2)
# DNSE_USERNAME=
# DNSE_PASSWORD=
