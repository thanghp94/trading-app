# Server
PORT=3001

# Auth — bearer token required on the WS handshake
APP_AUTH_TOKEN=change-me-to-a-random-32-char-string

# TwelveData — for real spot XAU/USD and forex pairs (works in VN).
# Sign up at https://twelvedata.com/register (free, ~2 min).
# Free tier: 800 req/day, 8 req/min. Adapter polls 110-180s per stream
# to stay safely under the daily quota for 1-2 active symbols.
# TWELVEDATA_API_KEY=

# OANDA practice account — alternative forex source. NOTE: OANDA blocks
# Vietnamese IPs, so this won't work from VN. Kept here for users in
# regions where OANDA is reachable.
# Sign up at https://www.oanda.com/apply/practice/ then generate a Personal
# Access Token at hub.oanda.com → Manage API Access.
# OANDA_API_TOKEN=
# OANDA_ACCOUNT_ID=

# Telegram (Weekend 3)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# VN broker creds (Weekend 3.2)
# DNSE_USERNAME=
# DNSE_PASSWORD=
